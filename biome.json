{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
  "files": { "includes": ["**", "!!**/dist"] },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80,
    "includes": ["**", "!**/migrations"]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "useImportType": "off",
        "noNonNullAssertion": "off",
        "useTemplate": "off",
        "useLiteralEnumMembers": "off",
        "noDescendingSpecificity": "off"
      },
      "suspicious": {
        "noConsole": "off",
        "noImplicitAnyLet": "off",
        "noAssignInExpressions": "off",
        "noDoubleEquals": "off",
        "noTemplateCurlyInString": "off"
      }
    }
  },
  "javascript": {
    "parser": { "unsafeParameterDecoratorsEnabled": true },
    "formatter": {
      "trailingCommas": "all",
      "semicolons": "always",
      "arrowParentheses": "always",
      "quoteStyle": "single"
    }
  },
  "assist": {
    "enabled": true,
    "actions": { "source": { "organizeImports": "on" } }
  },
  "overrides": [
    {
      "includes": ["*.spec.ts", "*.test.ts"],
      "linter": { "rules": { "suspicious": { "noConsole": "off" } } }
    },
    {
      "includes": ["*.css"],
      "linter": {
        "rules": {
          "complexity": { "noImportantStyles": "off" }
        }
      }
    }
  ]
}
