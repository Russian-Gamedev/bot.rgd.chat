{
  "name": "rgd-bot",
  "version": "1.0.0",
  "license": "ISC",
  "author": "RGD Community",
  "description": "",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Russian-Gamedev/rgd-bot.git"
  },
  "keywords": [],
  "bugs": {
    "url": "https://github.com/Russian-Gamedev/rgd-bot#issues"
  },
  "homepage": "https://github.com/Russian-Gamedev/rgd-bot#readme",
  "scripts": {
    "prepare": "bun ./.github/hooks/setup-git-hooks.sh",
    "start:dev": "bunx --bun nest start --env-file .env.development --watch",
    "build": "bun run build.ts",
    "compose:dev": "docker compose -f ./docker/docker-compose.dev.yml up",
    "compose:prod": "docker compose -f ./docker/docker-compose.yml up",
    "migration:create": "bunx --bun mikro-orm migration:create",
    "typecheck": "bunx --bun tsc --noEmit",
    "lint": "bunx --bun biome ci",
    "lint:fix": "bunx --bun biome check --write",
    "check:all": "bun run typecheck && bun run lint && bun test"
  },
  "mikro-orm": {
    "useTsNode": true,
    "configPaths": [
      "./src/mikro-orm.config.ts"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@mikro-orm/cli": "^7.1.5",
    "@nestjs/cli": "^11.0.23",
    "@types/bun": "^1.3.14",
    "@types/express": "^5.0.6",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@discordjs/voice": "^0.19.2",
    "@mikro-orm/core": "^7.1.5",
    "@mikro-orm/decorators": "^7.1.5",
    "@mikro-orm/migrations": "^7.1.5",
    "@mikro-orm/nestjs": "^7.0.1",
    "@mikro-orm/postgresql": "^7.1.5",
    "@necord/pagination": "^2.2.0",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/platform-ws": "^11.1.27",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.4.5",
    "@nestjs/websockets": "^11.1.27",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "discord.js": "^14.26.2",
    "ioredis": "^5.10.1",
    "necord": "npm:@damirlut/necord@latest",
    "openai": "^6.46.0",
    "passport": "^0.7.0",
    "passport-discord": "^0.1.4",
    "passport-jwt": "^4.0.1",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "trustedDependencies": [
    "@nestjs/core",
    "necord"
  ]
}
