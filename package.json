{
  "name": "rgd-bot",
  "version": "1.0.0",
  "license": "ISC",
  "author": "RGD Community",
  "description": "",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Russian-Gamedev/rgd-bot.git"
  },
  "keywords": [],
  "bugs": {
    "url": "https://github.com/Russian-Gamedev/rgd-bot#issues"
  },
  "homepage": "https://github.com/Russian-Gamedev/rgd-bot#readme",
  "scripts": {
    "prepare": "bun ./.github/hooks/setup-git-hooks.sh",
    "start:dev": "bunx --bun nest start --env-file .env.development --watch",
    "build": "bun run build.ts",
    "compose:dev": "docker compose -f ./docker/docker-compose.dev.yml up",
    "compose:prod": "docker compose -f ./docker/docker-compose.yml up",
    "migration:create": "bunx --bun mikro-orm migration:create",
    "typecheck": "bunx --bun tsc --noEmit",
    "lint": "bunx --bun eslint . --max-warnings=0",
    "lint:fix": "bunx --bun eslint . --fix --max-warnings=0",
    "check:all": "bun run typecheck && bun run lint && bun test"
  },
  "mikro-orm": {
    "useTsNode": true,
    "configPaths": [
      "./src/mikro-orm.config.ts"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@mikro-orm/cli": "^7.0.10",
    "@nestjs/cli": "^11.0.19",
    "@types/bun": "^1.3.12",
    "@types/express": "^5.0.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-eslint-plugin": "^7.3.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "typescript-eslint": "^8.58.1",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@discordjs/voice": "^0.19.2",
    "@mikro-orm/core": "^7.0.10",
    "@mikro-orm/decorators": "^7.0.10",
    "@mikro-orm/migrations": "^7.0.10",
    "@mikro-orm/nestjs": "^7.0.1",
    "@mikro-orm/postgresql": "^7.0.10",
    "@necord/pagination": "^2.2.0",
    "@nestjs/common": "^11.1.18",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.18",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/platform-ws": "^11.1.18",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.7",
    "@nestjs/websockets": "^11.1.18",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "discord.js": "^14.26.2",
    "ioredis": "^5.10.1",
    "necord": "^6.12.4",
    "nestjs-telegraf": "^2.9.1",
    "passport": "^0.7.0",
    "passport-discord": "^0.1.4",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "telegraf": "^4.16.3"
  },
  "trustedDependencies": [
    "@nestjs/core",
    "necord"
  ]
}
